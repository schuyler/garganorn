{
    "lexicon": 1,
    "id": "org.atgeo.place",
    "defs": {
        "relation": {
            "type": "object",
            "description": "A reference to a related place record.",
            "required": ["rkey"],
            "properties": {
                "rkey": {
                    "type": "string",
                    "description": "Collection-qualified record key (e.g. org.atgeo.places.wof:85922583).",
                    "format": "record-key"
                },
                "name": {
                    "type": "string",
                    "description": "Display name of the related place."
                },
                "level": {
                    "type": "integer",
                    "description": "Admin hierarchy level (0=continent, 10=country, 25=region, 50=locality, etc.)."
                }
            }
        },
        "variant": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The variant name text."
                },
                "type": {
                    "type": "string",
                    "description": "The kind of variant: official, alternate, short, colloquial, historical."
                },
                "language": {
                    "type": "string",
                    "description": "The language of the name.",
                    "format": "language"
                }
            }
        },
        "main": {
            "type": "record",
            "key": "record-key",
            "description": "A geographic place with location, name, and other attributes.",
            "record": {
                "type": "object",
                "required": ["name"],
                "properties": {
                    "rkey": {
                        "type": "string",
                        "description": "A globally unique identifier for this place record.",
                        "format": "record-key"
                    },
                    "locations": {
                        "type": "array",
                        "items": {
                            "type": "union",
                            "refs": [
                                "community.lexicon.location.geo",
                                "community.lexicon.location.hthree",
                                "community.lexicon.location.address",
                                "community.lexicon.location.bbox"
                            ]
                        },
                        "description": "The geographic location of the place, in any available representation."
                    },
                    "name": {
                        "type": "string",
                        "description": "The primary display name of the place."
                    },
                    "variants": {
                        "type": "array",
                        "description": "Alternate names, translations, and other name variants.",
                        "items": {
                            "type": "ref",
                            "ref": "#variant"
                        }
                    },
                    "attributes": {
                        "type": "unknown",
                        "description": "Additional, source-dependent attributes of the place."
                    },
                    "published_at": {
                        "type": "string",
                        "description": "The date when the place record was last updated",
                        "format": "datetime"
                    },
                    "relations": {
                        "type": "object",
                        "description": "Related records, keyed by relation type.",
                        "properties": {
                            "within": {
                                "type": "array",
                                "description": "Admin regions that geographically contain this place, ordered by level ascending.",
                                "items": {
                                    "type": "ref",
                                    "ref": "#relation"
                                }
                            },
                            "same_as": {
                                "type": "array",
                                "description": "Records in other collections or datasets that represent the same place.",
                                "items": {
                                    "type": "ref",
                                    "ref": "#relation"
                                }
                            }
                        }
                    }
                }
            }
        },
        "ref": {
            "type": "object",
            "description": "A reference to a geographic place defined elsewhere.",
            "required": ["id"],
            "properties": {
                "cid": {
                    "type": "string",
                    "description": "An optional reference to a specific version of the place definition.",
                    "format": "cid"
                },
                "id": {
                    "type": "string",
                    "description": "A globally unique identifier for the place.",
                    "format": "record-key"
                },
                "locations": {
                    "type": "array",
                    "items": {
                        "type": "union",
                        "refs": [
                            "community.lexicon.location.geo",
                            "community.lexicon.location.hthree",
                            "community.lexicon.location.address",
                            "community.lexicon.location.bbox"
                        ]
                    },
                    "description": "The geographic location of the place, in any available representation."
                },
                "name": {
                    "type": "string",
                    "description": "The primary display name of the place."
                },
                "attributes": {
                    "type": "unknown",
                    "description": "Additional attributes, included for durability or convenience."
                },
                "published_at": {
                    "type": "string",
                    "description": "The date when the place record was last updated",
                    "format": "datetime"
                }
            }
        }
    }
}
